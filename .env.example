# Flask secret — generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=replace-me-with-a-strong-random-secret

# App
FLASK_ENV=development
PORT=5002

# Default base currency for new users (ISO 4217 code)
DEFAULT_BASE_CURRENCY=EUR

# FX provider (frankfurter is free, no key required, ECB rates)
FX_PROVIDER=frankfurter

# Database — SQLite by default; switch to postgresql://user:pass@host/db for Postgres
DATABASE_URL=sqlite:///data/cosmo.db

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
