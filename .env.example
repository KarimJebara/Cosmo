# Cosmo configuration. Copy to .env and fill in.
# `docker compose up` reads .env automatically.

# REQUIRED. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-a-strong-random-secret

# Default base currency for new users (ISO 4217 code).
DEFAULT_BASE_CURRENCY=EUR

# FX provider (frankfurter is free, no key required, ECB rates).
FX_PROVIDER=frankfurter

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Host port to expose Cosmo on. Container always listens on 5002.
COSMO_PORT=5002

# gunicorn worker count. 2 is fine for SQLite; bump for Postgres.
GUNICORN_WORKERS=2

# Database. Inside Docker, defaults to sqlite:////data/budget_tracker.db
# (volume-backed). Override here for Postgres:
#   DATABASE_URL=postgresql+psycopg://cosmo:secret@db:5432/cosmo
# DATABASE_URL=
